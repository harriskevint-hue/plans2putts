# Data-pipeline database — a regenerable build-time artifact, NOT source of truth.
# Recreate it any time with: python3 integrations/data-pipeline/setup_db.py
# (The schema lives in setup_db.py; that script is what we version, not the .db.)
integrations/data-pipeline/courses.db

# SQLite side-files (created while the DB is open)
*.db-journal
*.db-wal
*.db-shm

# Generated review CSVs from the pipeline (regenerable; dry-run output is mock data)
integrations/data-pipeline/washington_courses_DRYRUN.csv
integrations/data-pipeline/washington_courses_review.csv

# Raw national pull output (regenerable; the CLEANED CSV is the committed seed)
integrations/data-pipeline/data/us_courses.csv
integrations/data-pipeline/data/raw/

# NAIP imagery pull output (large, regenerable PNGs + metadata; not source of truth)
integrations/data-pipeline/data/naip/

# Python bytecode cache
__pycache__/
*.pyc

# Secrets — never commit (repo is PUBLIC). API keys live in env / gitignored .env.
.env
.env.*
